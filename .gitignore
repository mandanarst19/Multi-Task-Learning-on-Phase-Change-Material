# ============================================================
# .gitignore — VO₂ Multi-Task Reservoir Computing project
# ============================================================

# --- Python byte-compiled / optimised / DLL files ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# --- Distribution / packaging ---
.Python
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# --- Virtual environments ---
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
# Keep notebooks tracked (remove line below to ignore all notebooks)
# *.ipynb

# --- PyTorch model checkpoints (can be large — upload to Zenodo/Figshare) ---
*.pth
*.pt
*.pkl
*.ckpt
# Exception: keep any tiny test fixtures
!tests/fixtures/*.pkl

# --- NumPy arrays (large intermediate files) ---
*.npy
*.npz

# --- Generated figures (regenerate from code — track only final paper figs) ---
figures/
!figures/.gitkeep

# --- Results / logs (large, reproducible from code) ---
results/
!results/.gitkeep

# --- Data (download automatically via torchvision) ---
data/
!data/.gitkeep

# --- Kaggle-specific ---
/kaggle/
*.kaggle

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
Desktop.ini

# --- Logs ---
*.log
logs/
*.out

# --- Profiling ---
*.prof

# --- Coverage ---
.coverage
htmlcov/
.pytest_cache/

# --- Temporary files ---
tmp/
temp/
*.tmp
*.bak
